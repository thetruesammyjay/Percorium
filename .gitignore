# =============================================================================
# PERCORIUM — .gitignore
# Monorepo: Rust/Anchor (programs/) + Next.js (apps/web/) + TypeScript SDK
# =============================================================================


# =============================================================================
# SECRETS & ENVIRONMENT — Never commit these
# =============================================================================
.env
.env.*
!.env.example
*.key
*.pem
*.p12
*.pfx

# Solana keypairs — CRITICAL: never commit wallet JSON files
id.json
*.json.local
~/.config/solana/


# =============================================================================
# RUST / CARGO
# =============================================================================
target/
**/*.rs.bk
Cargo.lock.bk

# Anchor build artifacts
.anchor/
programs/*/target/
programs/*/Cargo.lock

# IDL output (auto-generated — committed deliberately if stable)
# Uncomment the next line to also ignore IDLs:
# target/idl/
# target/types/

# Anchor test ledger (local validator state)
test-ledger/
.anchor/test-ledger/


# =============================================================================
# NODE / NPM / PNPM
# =============================================================================
node_modules/
**/node_modules/

# pnpm
.pnpm-store/
.pnpm-debug.log*

# Lock file conflicts — pnpm is canonical; ignore others
package-lock.json
yarn.lock

# npm debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*


# =============================================================================
# TURBOREPO
# =============================================================================
.turbo/
**/.turbo/


# =============================================================================
# NEXT.JS (apps/web/)
# =============================================================================
apps/web/.next/
apps/web/out/
apps/web/build/

# Next.js cache
apps/web/.next/cache/

# Next.js static export
apps/web/dist/

# Vercel
.vercel/
apps/web/.vercel/


# =============================================================================
# TYPESCRIPT
# =============================================================================
# Build output
dist/
**/dist/
build/
**/build/

# TypeScript cache
*.tsbuildinfo
**/*.tsbuildinfo

# Type generation output (auto-generated from Anchor IDL)
packages/sdk/src/idl.ts.bak


# =============================================================================
# TESTING
# =============================================================================
# Test coverage reports
coverage/
**/coverage/
lcov.info
*.lcov

# Jest
.jest-cache/

# Mocha / Anchor test output
*.test-results.json


# =============================================================================
# LOGS
# =============================================================================
*.log
logs/
**/logs/
*.log.*

# Anchor deploy logs
deploy.log
anchor-deploy.log


# =============================================================================
# SOLANA / ANCHOR SPECIFIC
# =============================================================================
# Program keypairs (devnet/mainnet deploy keys — keep out of git)
programs/percoria/target/deploy/*-keypair.json

# Anchor.toml overrides for local dev
Anchor.local.toml

# Address Lookup Table cache (regenerated by scripts/setup-luts.ts)
.luts-cache/
lut-cache.json

# Switchboard TEE function build artifacts
switchboard-function/target/
switchboard-function/.docker/

# Solana local validator ledger
test-validator/
.test-ledger/


# =============================================================================
# EDITORS & IDEs
# =============================================================================
# VS Code
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example

# JetBrains (CLion, IntelliJ)
.idea/
*.iml
*.iws
*.ipr

# Vim / Neovim
*.swp
*.swo
*~
.netrwhist

# Emacs
*#
.#*

# Sublime Text
*.sublime-project
*.sublime-workspace


# =============================================================================
# OPERATING SYSTEM
# =============================================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~


# =============================================================================
# DOCKER (for Switchboard TEE function builds)
# =============================================================================
.docker/
docker-compose.override.yml


# =============================================================================
# COLOSSEUM / HACKATHON ARTEFACTS
# =============================================================================
# Demo video files (too large for git — use LFS or external host)
*.mp4
*.mov
*.avi
*.mkv
*.webm

# Large images / design files
*.psd
*.sketch
*.fig
*.ai
*.xcf

# Presentation exports (use source files only)
docs/colosseum/*.pdf
docs/colosseum/*.pptx


# =============================================================================
# MISCELLANEOUS
# =============================================================================
# Temporary files
*.tmp
*.temp
tmp/
temp/

# Cache directories
.cache/
**/.cache/

# Snapshot files (generated by anchor snapshot)
snapshots/

# Wasm build artifacts (if FHE bindings produce wasm output)
*.wasm
pkg/
wasm-pack.log
